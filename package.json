{
  "name": "gcp-oauth-automator",
  "version": "2.0.0",
  "description": "Automate Google OAuth 2.0 client setup via Playwright — create new clients or renew credentials. Cross-platform: Windows, macOS, Linux.",
  "type": "module",
  "scripts": {
    "create": "node scripts/oauth-client.mjs create",
    "renew": "node scripts/oauth-client.mjs renew"
  },
  "keywords": ["gcp", "oauth", "playwright", "automation", "google-auth", "cli", "google-cloud", "oauth2", "google-cloud-platform", "credentials"],
  "author": "Z1Code",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.50.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
